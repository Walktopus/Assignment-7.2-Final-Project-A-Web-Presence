//this is the variable that controls the motion of the image
var intervalidID = 0;
//this variable controls how far from the bottom the image is when it starts moving
var startBottom = 200;
//this variable controls how far from the left the image is when it starts moving
var startleft = 250;
//this variable helps control the movement of the image in relation to the left
var dleft = 5;
//this variable helps control the movement of the image in relation to the bottom
var dbottom = 5;
//This is the function that allows the image move
function imagemover(){
    //this is where the intervaildID contorls the motion of the image
intervalidID = setInterval(imagebounce, 100);

}
//this function is the funtion that move the image
function imagebounce(){
    //this variable is what translates the image data to this javascript file
     var imageCat = document.getElementById("imgCat");
     //this style property controls the speed of the image to the left
     imageCat.style.right = startleft + "px";
     //this style property controls the speed of the image from the bottom
    imageCat.style.bottom = startBottom + "px";
    //this if statment controls the left variables
    //this document property apllies the styles above to the image
    if ((startleft +imageCat.width >= window.innerWidth) || (startleft <=0) )
        {       

            dleft = -dleft;
        }
    
    //this if statment controls the bottom variables
        if ((startBottom + imageCat.height - 30 >= window.innerHeight) || (startBottom <=0))
        {  
            dbottom = -dbottom;
        }
        //this is just math that allows the code above to work
        startBottom += dbottom;
               //this is just math that allows the code above to work
        startleft +=dleft;        
        //this is to change the background when the start button is pressed
        document.body.style.backgroundColor = "darkgreen";
}
//this function stops the image
function imagestopper(){
    //this clears the motion from the image
clearInterval(intervalidID);
//this changes the color of the background back to black
document.body.style.backgroundColor = "black";
}

